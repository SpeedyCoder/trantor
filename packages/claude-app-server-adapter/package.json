{
  "name": "claude-app-server-adapter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "claude-app-server-adapter": "./dist/index.js"
  },
  "scripts": {
    "tsc": "tsc --noEmit",
    "build": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "generate:app-server-types": "node generate-claude-app-server-types.mjs",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.112"
  }
}
